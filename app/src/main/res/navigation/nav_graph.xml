<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.budakattu_sante.ui.fragment.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_onboarding"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.example.budakattu_sante.ui.fragment.OnboardingFragment"
        android:label="Onboarding"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboarding_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.budakattu_sante.ui.fragment.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.budakattu_sante.ui.fragment.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_productDetail"
            app:destination="@id/productDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.example.budakattu_sante.ui.fragment.ProductDetailFragment"
        android:label="Product Detail"
        tools:layout="@layout/fragment_product_detail" />

    <fragment
        android:id="@+id/preOrdersFragment"
        android:name="com.example.budakattu_sante.ui.fragment.PreOrdersFragment"
        android:label="Pre-Orders"
        tools:layout="@layout/fragment_pre_orders" />

    <fragment
        android:id="@+id/supplyLogFragment"
        android:name="com.example.budakattu_sante.ui.fragment.SupplyLogFragment"
        android:label="Supply Log"
        tools:layout="@layout/fragment_supply_log" />

    <fragment
        android:id="@+id/mspInfoFragment"
        android:name="com.example.budakattu_sante.ui.fragment.MspInfoFragment"
        android:label="MSP Info"
        tools:layout="@layout/fragment_msp_info" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.budakattu_sante.ui.fragment.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/leaderDashboardFragment"
        android:name="com.example.budakattu_sante.ui.fragment.LeaderDashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_leader_dashboard" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.budakattu_sante.ui.fragment.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/customerListFragment"
        android:name="com.example.budakattu_sante.ui.fragment.CustomerListFragment"
        android:label="Customers"
        tools:layout="@layout/fragment_customer_list" />

</navigation>
